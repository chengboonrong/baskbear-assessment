# Copy to .env and edit for your environment.
# iOS simulator can reach the host via http://localhost.
# Android emulator must use http://10.0.2.2 (host loopback).
API_BASE_URL=http://localhost:3000

# Local-dev shortcut: token is "Bearer dev:<sub>", server bypasses Cognito JWKS.
# Set to a real Cognito access token (or remove) when running against AWS.
DEV_BEARER_TOKEN=dev:demo-user-sub

# Cognito (only used when DEV_BEARER_TOKEN is empty)
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
COGNITO_REGION=ap-southeast-1
COGNITO_HOSTED_UI_DOMAIN=

# Compile-time defaults used before the user has finished onboarding.
# Once onboarding completes, the chosen country+locale persist in SharedPreferences.
# Should match the API's DEFAULT_COUNTRY_CODE for a consistent first-launch experience.
DEFAULT_COUNTRY=MY
DEFAULT_LOCALE=en

# --- AI Barista (optional) ----------------------------------------------------
# The Barista tab works out of the box using an offline keyword recommender.
# To enable the on-device Gemma LLM, leave the default model URL below and add a
# HuggingFace token: the repo is GATED, so open the URL once in a browser, accept
# the Gemma license, then create a read token at
# https://huggingface.co/settings/tokens and paste it into HUGGINGFACE_TOKEN.
# NOTE: real on-device inference only runs reliably on PHYSICAL devices —
# emulators and the iOS Simulator fall back to the keyword recommender.
GEMMA_MODEL_URL=https://huggingface.co/litert-community/Gemma3-1B-IT/resolve/main/gemma3-1b-it-int4.task
HUGGINGFACE_TOKEN=
