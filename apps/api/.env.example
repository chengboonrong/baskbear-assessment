# Copy to .env and fill in real values.

# --- Database -----------------------------------------------------------------
DATABASE_URL="mysql://root:password@localhost:3306/baskbear"

# --- Server -------------------------------------------------------------------
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# --- Auth (AWS Cognito) -------------------------------------------------------
# Region & user pool that issues JWTs the API will trust.
COGNITO_REGION=ap-southeast-1
COGNITO_USER_POOL_ID=ap-southeast-1_xxxxxxx
COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
# Comma-separated list of audiences (app client ids) accepted on token verify.
COGNITO_ALLOWED_AUDIENCES=

# Dev-only bypass: when "true", API accepts any "Bearer dev:<cognito_sub>" token
# instead of verifying with JWKS. Never enable in production.
DEV_AUTH_BYPASS=true
DEV_DEFAULT_SUB=demo-user-sub

# --- Defaults -----------------------------------------------------------------
DEFAULT_COUNTRY_CODE=MY
